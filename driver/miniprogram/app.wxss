page {
  height: 100%;
  background: #f5f8fc;
  color: #17324b;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  height: 100vh;
  background: #f5f8fc;
}

.page-body {
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(82, 112, 152, 0.08);
  border-radius: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #17324b;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6c7f95;
  line-height: 1.5;
}

.muted {
  color: #6c7f95;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2f62d9;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button,
.ghost-button,
.chip-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.primary-button {
  background: #2f69d8;
  color: #ffffff;
}

.ghost-button {
  background: #f4f7fb;
  color: #2b4968;
}

.chip-button {
  background: #eef4ff;
  color: #335073;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: #fbfcfe;
  border: 1rpx solid rgba(82, 112, 152, 0.08);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #74859a;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #17324b;
}

.stat-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6c7f95;
}

.safe-bottom {
  height: 72rpx;
}

.light-card {
  background: #fff;
}

.driver-page-shell {
  padding: 28rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.driver-page-hero {
  padding: 28rpx;
  background: #fdfefe;
}

.driver-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.driver-kicker {
  font-size: 22rpx;
  color: #6c7f95;
  font-weight: 800;
}

.driver-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
  color: #17324b;
}

.driver-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6c7f95;
  line-height: 1.5;
}

.driver-status {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e9f1ff;
  color: #2f62d9;
  font-size: 22rpx;
  font-weight: 800;
}

.driver-section {
  margin-top: 18rpx;
}

.banner-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.banner-pill {
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #3a5577;
  font-size: 20rpx;
  font-weight: 700;
}

.panel {
  padding: 22rpx;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #17324b;
}

.panel-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6c7f95;
  line-height: 1.5;
}

.panel-action {
  flex: none;
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #3158cb;
  font-size: 20rpx;
  font-weight: 800;
}
