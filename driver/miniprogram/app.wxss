/** app.wxss */
page {
  height: 100%;
  background:
    radial-gradient(circle at top left, rgba(77, 129, 255, 0.14), transparent 30%),
    radial-gradient(circle at top right, rgba(255, 179, 92, 0.18), transparent 28%),
    linear-gradient(180deg, #f5f8ff 0%, #f9fbff 42%, #eef4fb 100%);
  color: #15304a;
  font-family: PingFang SC, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  height: 100vh;
}

.page-body {
  padding: 28rpx 24rpx 72rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(89, 123, 170, 0.12);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 48rpx rgba(58, 92, 131, 0.08);
  backdrop-filter: blur(10px);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #15304a;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7f98;
  line-height: 1.5;
}

.muted {
  color: #6b7f98;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(77, 129, 255, 0.1);
  color: #3056c9;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button,
.ghost-button,
.chip-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.primary-button {
  background: linear-gradient(135deg, #4d81ff, #2f69d8);
  color: #fff;
}

.ghost-button {
  background: #f4f7fc;
  color: #2b4968;
}

.chip-button {
  background: #eef4ff;
  color: #335073;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #eef4fb 100%);
  border: 1rpx solid rgba(89, 123, 170, 0.12);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #7386a0;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #14304b;
}

.stat-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6b7f98;
}

.safe-bottom {
  height: 72rpx;
}

.light-card {
  background: #fff;
}
