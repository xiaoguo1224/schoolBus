/** app.wxss */
page {
  height: 100%;
  background:
    radial-gradient(circle at top right, rgba(255, 186, 73, 0.14), transparent 28%),
    linear-gradient(180deg, #0f1720 0%, #111c28 42%, #0e1520 100%);
  color: #ecf2f7;
  font-family: PingFang SC, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  height: 100vh;
}

.page-body {
  padding: 28rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(18, 28, 39, 0.9);
  border: 1rpx solid rgba(141, 169, 191, 0.14);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.2);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #f5f8fa;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9fb0bd;
  line-height: 1.5;
}

.muted {
  color: #9fb0bd;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 186, 73, 0.12);
  color: #ffd48d;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button,
.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.primary-button {
  background: linear-gradient(135deg, #ffbf4d, #ff8f4d);
  color: #211406;
}

.ghost-button {
  background: #172230;
  color: #d7e1ea;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(26, 39, 53, 0.96) 0%, rgba(18, 28, 39, 0.96) 100%);
  border: 1rpx solid rgba(141, 169, 191, 0.12);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #9fb0bd;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #ffffff;
}

.stat-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #8ba0af;
}

.safe-bottom {
  height: 24rpx;
}
