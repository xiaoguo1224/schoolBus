.tasks-grid {
  display: grid;
  grid-template-columns: 1.02fr 0.98fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.task-list,
.alert-list,
.notice-list,
.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.task-card {
  padding: 22rpx;
  border-color: rgba(89, 123, 170, 0.12);
}

.task-card.is-active {
  border-color: rgba(77, 129, 255, 0.32);
  box-shadow: 0 16rpx 34rpx rgba(77, 129, 255, 0.08);
}

.task-top,
.current-row,
.timeline-line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #17314b;
}

.task-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7f98;
}

.task-badge {
  flex: none;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(77, 129, 255, 0.12);
  color: #2f62d9;
  font-size: 20rpx;
  font-weight: 800;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
  font-size: 20rpx;
  color: #5e7591;
}

.current-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-row + .current-row {
  margin-top: 14rpx;
}

.current-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-label,
.timeline-label {
  display: block;
  font-size: 20rpx;
  color: #6b7f98;
}

.current-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.timeline-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.timeline-headline {
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
  margin-bottom: 14rpx;
}

.timeline-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.timeline-pin {
  width: 18rpx;
  height: 18rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: #c7d5e7;
  flex: none;
}

.timeline-pin.done {
  background: #6fcf97;
}

.timeline-pin.doing {
  background: #4d81ff;
}

.timeline-pin.todo {
  background: #f6bc53;
}

.timeline-copy {
  flex: 1;
}

.timeline-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #17314b;
}

.timeline-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #6b7f98;
}

.feed-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.feed-panel {
  min-height: 100%;
}

.alert-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.alert-card.good {
  background: rgba(111, 207, 151, 0.12);
}

.alert-card.warn {
  background: rgba(246, 188, 83, 0.14);
}

.alert-card.alert {
  background: rgba(255, 126, 120, 0.12);
}

.alert-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #17314b;
}

.alert-meta,
.notice-card {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5e7591;
  line-height: 1.5;
}

.notice-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

@media (max-width: 860px) {
  .tasks-grid {
    grid-template-columns: 1fr;
  }

  .feed-grid {
    grid-template-columns: 1fr;
  }

  .action-row {
    grid-template-columns: 1fr;
  }
}
