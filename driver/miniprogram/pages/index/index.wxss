.driver-home {
  padding-bottom: 0;
}

.driver-hero {
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(77, 129, 255, 0.16), transparent 28%),
    radial-gradient(circle at bottom left, rgba(255, 179, 92, 0.18), transparent 26%),
    linear-gradient(135deg, #ffffff 0%, #f7fbff 100%);
}

.driver-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.driver-kicker {
  font-size: 22rpx;
  color: #6a7f99;
  font-weight: 800;
}

.driver-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
  color: #16314d;
}

.driver-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7f98;
  line-height: 1.5;
}

.driver-status {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(77, 129, 255, 0.12);
  color: #2f62d9;
  font-size: 22rpx;
  font-weight: 800;
}

.banner-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.banner-pill {
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #3a5577;
  font-size: 20rpx;
  font-weight: 700;
}

.stats-grid {
  margin-top: 20rpx;
}

.view-tabs {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.view-tip {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(77, 129, 255, 0.08);
  color: #35506f;
  font-size: 20rpx;
  line-height: 1.5;
}

.view-tab {
  padding: 16rpx 14rpx;
  border-radius: 22rpx;
  background: #f3f7fd;
  border: 1rpx solid rgba(89, 123, 170, 0.12);
}

.view-tab.is-active {
  background: linear-gradient(135deg, rgba(77, 129, 255, 0.14), rgba(62, 184, 161, 0.12));
  border-color: rgba(77, 129, 255, 0.2);
}

.view-tab-label {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #17314b;
}

.view-tab-hint {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #6b7f98;
  line-height: 1.3;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: 1.02fr 0.98fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.panel {
  padding: 22rpx;
}

.wide-panel {
  margin-top: 18rpx;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #17314b;
}

.panel-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7f98;
  line-height: 1.5;
}

.panel-action {
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #3158cb;
  font-size: 20rpx;
  font-weight: 800;
}

.task-list,
.rating-list,
.alert-list,
.notice-list,
.step-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.task-card {
  padding: 22rpx;
  border-color: rgba(89, 123, 170, 0.12);
}

.task-card.is-active {
  border-color: rgba(77, 129, 255, 0.32);
  box-shadow: 0 16rpx 34rpx rgba(77, 129, 255, 0.08);
}

.task-top,
.current-row,
.route-summary,
.route-summary-item,
.timeline-line,
.step-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.task-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #17314b;
}

.task-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7f98;
}

.task-badge {
  flex: none;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(77, 129, 255, 0.12);
  color: #2f62d9;
  font-size: 20rpx;
  font-weight: 800;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
  font-size: 20rpx;
  color: #5e7591;
}

.current-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-row + .current-row {
  margin-top: 14rpx;
}

.current-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-label,
.route-summary-label,
.check-label,
.step-time,
.timeline-label {
  display: block;
  font-size: 20rpx;
  color: #6b7f98;
}

.current-value,
.route-summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.timeline-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.timeline-headline {
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
  margin-bottom: 14rpx;
}

.timeline-item,
.step-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.timeline-pin {
  width: 18rpx;
  height: 18rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: #c7d5e7;
  flex: none;
}

.timeline-pin.done {
  background: #6fcf97;
}

.timeline-pin.doing {
  background: #4d81ff;
}

.timeline-pin.todo {
  background: #f6bc53;
}

.timeline-copy,
.step-copy {
  flex: 1;
}

.timeline-title,
.step-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #17314b;
}

.timeline-desc,
.step-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #6b7f98;
}

.vehicle-hero {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(77, 129, 255, 0.08), rgba(62, 184, 161, 0.1));
}

.vehicle-id {
  font-size: 34rpx;
  font-weight: 900;
  color: #17314b;
}

.vehicle-model {
  font-size: 24rpx;
  color: #5e7591;
}

.vehicle-chip {
  margin-left: auto;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #2f62d9;
  font-size: 20rpx;
  font-weight: 800;
}

.check-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.check-card {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.check-value {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #17314b;
}

.progress-track {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 18rpx;
  padding: 0 8rpx;
}

.progress-line {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 18rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #6fcf97, #4d81ff, #c7d5e7);
}

.progress-point {
  position: relative;
  padding-top: 38rpx;
  font-size: 20rpx;
  text-align: center;
  color: #6b7f98;
  font-weight: 700;
}

.progress-point::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: #d8e2ee;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 1rpx rgba(89, 123, 170, 0.1);
}

.progress-point.is-done::before {
  background: #6fcf97;
}

.progress-point.is-current::before {
  background: #4d81ff;
}

.route-summary {
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.route-summary-item {
  flex-direction: column;
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.report-grid {
  display: grid;
  grid-template-columns: 1fr 0.92fr;
  gap: 16rpx;
}

.report-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.report-option {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.report-option.is-active {
  background: linear-gradient(135deg, rgba(77, 129, 255, 0.12), rgba(62, 184, 161, 0.12));
  border-color: rgba(77, 129, 255, 0.2);
}

.report-label {
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
}

.report-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #6b7f98;
  line-height: 1.4;
}

.report-preview {
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #eff5ff 100%);
  border: 1rpx solid rgba(89, 123, 170, 0.12);
}

.preview-kicker {
  font-size: 20rpx;
  color: #6b7f98;
  text-transform: uppercase;
  letter-spacing: 0.16em;
}

.preview-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #17314b;
}

.preview-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #56708b;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.preview-tag {
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #3158cb;
  font-size: 20rpx;
  font-weight: 700;
}

.feed-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.feed-panel {
  min-height: 100%;
}

.alert-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.alert-card.good {
  background: rgba(111, 207, 151, 0.12);
}

.alert-card.warn {
  background: rgba(246, 188, 83, 0.14);
}

.alert-card.alert {
  background: rgba(255, 126, 120, 0.12);
}

.alert-title,
.rating-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #17314b;
}

.alert-meta,
.rating-score,
.rating-note,
.notice-card {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5e7591;
  line-height: 1.5;
}

.notice-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.rating-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.rating-score {
  font-size: 24rpx;
  font-weight: 800;
  color: #2f62d9;
}

.rating-note {
  color: #6b7f98;
}
