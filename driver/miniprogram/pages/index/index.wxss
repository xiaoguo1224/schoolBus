.index-stats {
  margin-top: 18rpx;
}

.index-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.mini-task-list,
.alert-list,
.notice-list,
.timeline-list,
.quick-entry-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mini-task-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.mini-task-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.mini-task-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #17314b;
}

.mini-task-status {
  flex: none;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(77, 129, 255, 0.12);
  color: #3158cb;
  font-size: 18rpx;
  font-weight: 800;
}

.mini-task-sub,
.mini-task-note,
.notice-card,
.quick-entry {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #5e7591;
  line-height: 1.5;
}

.quick-entry {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #3158cb;
  font-weight: 800;
}

.alert-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.alert-card.good {
  background: rgba(111, 207, 151, 0.12);
}

.alert-card.warn {
  background: rgba(246, 188, 83, 0.14);
}

.alert-card.alert {
  background: rgba(255, 126, 120, 0.12);
}

.alert-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #17314b;
}

.alert-meta {
  margin-top: 8rpx;
}

.notice-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.timeline-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fbfdff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.timeline-headline {
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
  margin-bottom: 14rpx;
}

.timeline-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.timeline-pin {
  width: 18rpx;
  height: 18rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: #c7d5e7;
  flex: none;
}

.timeline-pin.done {
  background: #6fcf97;
}

.timeline-pin.doing {
  background: #4d81ff;
}

.timeline-pin.todo {
  background: #f6bc53;
}

.timeline-copy {
  flex: 1;
}

.timeline-line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.timeline-label {
  display: block;
  font-size: 20rpx;
  color: #6b7f98;
}

.timeline-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #17314b;
}

.timeline-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #6b7f98;
}

@media (max-width: 860px) {
  .index-grid {
    grid-template-columns: 1fr;
  }
}
