<view class="app-shell">
  <scroll-view class="content-scroll" scroll-y>
    <view class="driver-page-shell index-page" style="padding-top: {{topInset}}px;">
      <view class="driver-page-hero card">
        <view class="driver-hero-top">
          <view>
            <view class="driver-kicker">司机小程序 · 首页总览</view>
            <view class="driver-title">{{driverName}}</view>
            <view class="driver-subtitle">{{driverRole}}</view>
          </view>
          <view class="driver-status">在线</view>
        </view>

        <view class="banner-strip">
          <view wx:for="{{summaryBanners}}" wx:key="index" class="banner-pill">{{item}}</view>
        </view>

        <view class="driver-nav-grid">
          <view
            wx:for="{{driverPages}}"
            wx:key="key"
            class="driver-nav-item {{activePage === item.key ? 'is-active' : ''}}"
            data-url="{{item.path}}"
            bindtap="onNavigate"
          >
            <text class="driver-nav-label">{{item.label}}</text>
            <text class="driver-nav-hint">{{item.hint}}</text>
          </view>
        </view>
      </view>

      <view class="grid-2 index-stats">
        <view wx:for="{{driverStats}}" wx:key="label" class="stat-card">
          <text class="stat-label">{{item.label}}</text>
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-hint">{{item.hint}}</text>
        </view>
      </view>

      <view class="index-grid">
        <view class="panel card">
          <view class="panel-header">
            <view>
              <view class="panel-title">今日任务</view>
              <view class="panel-subtitle">点击卡片进入“今日任务”独立页面。</view>
            </view>
            <view class="panel-action" data-url="/pages/tasks/tasks" bindtap="onOpenPage">去任务页</view>
          </view>

          <view class="mini-task-list">
            <view wx:for="{{todayTasks}}" wx:key="id" class="mini-task-card">
              <view class="mini-task-top">
                <view class="mini-task-title">{{item.routeName}}</view>
                <view class="mini-task-status">{{item.status}}</view>
              </view>
              <view class="mini-task-sub">{{item.departTime}} - {{item.arriveTime}} · {{item.vehicle}}</view>
              <view class="mini-task-note">{{item.note}}</view>
            </view>
          </view>
        </view>

        <view class="panel card">
          <view class="panel-header">
            <view>
              <view class="panel-title">调度提醒</view>
              <view class="panel-subtitle">呼叫提醒、行程节奏和热点提示同步展示。</view>
            </view>
            <view class="panel-action" data-url="/pages/trip/trip" bindtap="onOpenPage">去行程页</view>
          </view>

          <view class="alert-list">
            <view wx:for="{{callAlerts}}" wx:key="id" class="alert-card {{item.tone}}">
              <view class="alert-title">{{item.title}}</view>
              <view class="alert-meta">{{item.station}} · {{item.count}}</view>
            </view>
          </view>

          <view class="timeline-card" style="margin-top: 18rpx;">
            <view class="timeline-headline">执行节奏</view>
            <view class="timeline-list">
              <view wx:for="{{tripTimeline}}" wx:key="label" class="timeline-item">
                <view class="timeline-pin {{item.tone}}"></view>
                <view class="timeline-copy">
                  <view class="timeline-line">
                    <text class="timeline-label">{{item.label}}</text>
                    <text class="timeline-title">{{item.title}}</text>
                  </view>
                  <view class="timeline-desc">{{item.desc}}</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="index-grid">
        <view class="panel card">
          <view class="panel-header">
            <view>
              <view class="panel-title">快捷入口</view>
              <view class="panel-subtitle">直接进入车辆、异常和考勤页面。</view>
            </view>
          </view>

          <view class="quick-entry-grid">
            <view class="quick-entry" data-url="/pages/vehicle/vehicle" bindtap="onOpenPage">车辆绑定</view>
            <view class="quick-entry" data-url="/pages/report/report" bindtap="onOpenPage">异常上报</view>
            <view class="quick-entry" data-url="/pages/attendance/attendance" bindtap="onOpenPage">考勤评价</view>
            <view class="quick-entry" data-url="/pages/logs/logs" bindtap="onOpenPage">流水记录</view>
          </view>
        </view>

        <view class="panel card">
          <view class="panel-header">
            <view>
              <view class="panel-title">页面说明</view>
              <view class="panel-subtitle">这不是单页堆叠，而是多个真实页面之间切换。</view>
            </view>
          </view>

          <view class="notice-list">
            <view class="notice-card">任务、车辆、行程、异常和考勤都已拆成独立页面。</view>
            <view class="notice-card">顶部入口保持固定，方便在演示时来回切换。</view>
          </view>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </scroll-view>
</view>
