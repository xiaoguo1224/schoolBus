.attendance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.notice-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
  color: #5e7591;
  font-size: 22rpx;
  line-height: 1.5;
}

.rating-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.rating-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.rating-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #17314b;
}

.rating-score {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #2f62d9;
}

.rating-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7f98;
  line-height: 1.5;
}

@media (max-width: 860px) {
  .attendance-grid {
    grid-template-columns: 1fr;
  }
}
