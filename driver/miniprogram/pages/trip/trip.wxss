.trip-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.progress-track {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 18rpx;
  padding: 0 8rpx;
}

.progress-line {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 18rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #6fcf97, #4d81ff, #c7d5e7);
}

.progress-point {
  position: relative;
  padding-top: 38rpx;
  font-size: 20rpx;
  text-align: center;
  color: #6b7f98;
  font-weight: 700;
}

.progress-point::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: #d8e2ee;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 1rpx rgba(89, 123, 170, 0.1);
}

.progress-point.is-done::before {
  background: #6fcf97;
}

.progress-point.is-current::before {
  background: #4d81ff;
}

.current-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-row + .current-row {
  margin-top: 14rpx;
}

.current-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.current-label,
.route-summary-label,
.step-time {
  display: block;
  font-size: 20rpx;
  color: #6b7f98;
}

.current-value,
.route-summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #17314b;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.route-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.route-summary-item {
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f5f8fd;
  border: 1rpx solid rgba(89, 123, 170, 0.08);
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.step-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.step-copy {
  flex: 1;
}

.step-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #17314b;
}

.step-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #6b7f98;
}

.trip-actions {
  margin-top: 18rpx;
}

@media (max-width: 860px) {
  .trip-grid,
  .action-row {
    grid-template-columns: 1fr;
  }
}
