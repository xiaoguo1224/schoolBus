.mine-page {
  padding-bottom: 0;
}

.mine-hero {
  padding: 26rpx;
  background:
    radial-gradient(circle at top right, rgba(103, 164, 255, 0.14), transparent 26%),
    linear-gradient(135deg, #f8fbff 0%, #eff9eb 100%);
}

.mine-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-block {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #b5ff63, #8ae85a);
  color: #173313;
  font-size: 34rpx;
  font-weight: 900;
}

.mine-copy {
  flex: 1;
}

.mine-name {
  font-size: 34rpx;
  font-weight: 900;
}

.mine-campus {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6e7e6c;
}

.mine-tag {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eff8ea;
  color: #4b6f43;
  font-size: 20rpx;
  font-weight: 800;
}

.mine-stats {
  margin-top: 20rpx;
}

.mine-service,
.record-card,
.coupon-card,
.feedback-card,
.ebike-card {
  padding: 22rpx;
}

.mine-service-title,
.record-title,
.coupon-title,
.feedback-title,
.ebike-name {
  font-size: 28rpx;
  font-weight: 900;
}

.mine-service-desc,
.record-sub,
.coupon-rule,
.coupon-expiry,
.feedback-meta,
.ebike-meta,
.ebike-rule {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6f7e6c;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.record-top,
.coupon-top,
.feedback-top,
.ebike-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.record-badge,
.feedback-status,
.ebike-status,
.coupon-tag {
  flex: none;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #eff8ea;
  color: #4b6f43;
  font-size: 20rpx;
  font-weight: 800;
}

.record-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
  font-size: 20rpx;
  color: #50634c;
}
