.map-shell {
  background: linear-gradient(180deg, #dbf9d7 0%, #eef9e9 18%, #eef9e9 100%);
}

.map-page {
  padding-bottom: 40rpx;
}

.map-header {
  padding: 28rpx;
}

.map-header-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.map-kicker {
  font-size: 22rpx;
  color: #6c8269;
  font-weight: 700;
}

.map-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #172015;
}

.map-back {
  flex: none;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f2f8ef;
  color: #4c6149;
  font-size: 24rpx;
  font-weight: 700;
}

.map-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6f7e6c;
  line-height: 1.6;
}

.map-legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.map-legend-chip {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #eef9e9;
  color: #4b7540;
  font-size: 20rpx;
  font-weight: 700;
}

.route-strip {
  margin-top: 18rpx;
  white-space: nowrap;
}

.route-strip-inner {
  display: inline-flex;
  padding: 2rpx 4rpx 12rpx;
}

.route-chip {
  width: 250rpx;
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(174, 214, 168, 0.45);
  margin-right: 16rpx;
  box-sizing: border-box;
}

.route-chip.is-active {
  background: linear-gradient(135deg, #b8ff64, #8be95a);
  border-color: transparent;
}

.route-chip-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #172015;
}

.route-chip-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #5f6e5d;
}

.route-chip.is-active .route-chip-subtitle {
  color: #23411f;
}

.map-frame {
  position: relative;
  margin-top: 12rpx;
  padding: 16rpx;
  overflow: hidden;
}

.map-frame-label {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.map-frame-label-main {
  font-size: 28rpx;
  font-weight: 900;
  color: #172015;
}

.map-frame-label-sub {
  font-size: 22rpx;
  color: #6f7e6c;
}

.bus-map {
  width: 100%;
  height: 900rpx;
  border-radius: 30rpx;
  overflow: hidden;
}

.map-overlay {
  position: absolute;
  left: 26rpx;
  top: 96rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  z-index: 20;
}

.map-overlay-chip {
  display: inline-flex;
  align-self: flex-start;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #35506b;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(39, 58, 32, 0.08);
}

.map-overlay-chip.is-main {
  background: linear-gradient(135deg, #b8ff64, #8be95a);
  color: #173313;
}

.map-floating {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 20;
}

.float-button {
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(111, 142, 106, 0.16);
  color: #1c2d18;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(39, 58, 32, 0.12);
}

.map-summary,
.map-timeline,
.map-list {
  margin-top: 18rpx;
  padding: 24rpx;
}

.summary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 900;
}

.summary-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f7e6c;
  line-height: 1.5;
}

.summary-status {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef9e9;
  color: #4b7540;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.summary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.summary-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f8ef;
  color: #4b7540;
  font-size: 20rpx;
  font-weight: 700;
}

.stat-box {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: #f5faf2;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #72806f;
}

.stat-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.selected-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
}

.line-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  margin-top: 9rpx;
  background: linear-gradient(135deg, #b5ff63, #8ae85a);
  flex: none;
}

.line-copy {
  flex: 1;
}

.line-title {
  font-size: 28rpx;
  font-weight: 800;
}

.line-text {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6f7e6c;
  line-height: 1.5;
}

.timeline-list {
  margin-top: 18rpx;
}

.timeline-item {
  display: flex;
  gap: 14rpx;
}

.timeline-item + .timeline-item {
  margin-top: 18rpx;
}

.timeline-mark {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
  flex: none;
  background: #adc6a9;
}

.timeline-mark.start {
  background: #78d24d;
}

.timeline-mark.stop {
  background: #82bfff;
}

.timeline-mark.end {
  background: #7b65ff;
}

.timeline-copy {
  flex: 1;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(100, 135, 92, 0.12);
}

.timeline-item:last-child .timeline-copy {
  border-bottom: none;
  padding-bottom: 0;
}

.timeline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.timeline-name {
  font-size: 28rpx;
  font-weight: 800;
}

.timeline-kind {
  font-size: 22rpx;
  color: #6f7e6c;
}

.timeline-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4f7d45;
  font-weight: 700;
}

.fleet-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.fleet-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f6faf3;
  border: 1rpx solid transparent;
}

.fleet-card.is-active {
  background: #eafce2;
  border-color: rgba(78, 130, 54, 0.2);
}

.fleet-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.fleet-name {
  font-size: 28rpx;
  font-weight: 800;
}

.fleet-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 20rpx;
  color: #4b7540;
  font-weight: 700;
}

.fleet-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6f7e6c;
}

.fleet-direction {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #35506b;
  font-weight: 700;
}
