.ride-page {
  padding-bottom: 0;
}

.ride-hero {
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 201, 120, 0.28), transparent 28%),
    linear-gradient(135deg, #fff9f0 0%, #f6fbf3 100%);
}

.ride-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.ride-kicker {
  font-size: 22rpx;
  color: #7d715b;
  font-weight: 800;
}

.ride-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.ride-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f7e6c;
  line-height: 1.5;
}

.ride-status {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff3df;
  color: #9a6810;
  font-size: 22rpx;
  font-weight: 800;
}

.qr-panel {
  margin-top: 22rpx;
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.qr-box {
  width: 240rpx;
  height: 240rpx;
  border-radius: 30rpx;
  background: #fff;
  border: 1rpx solid rgba(94, 131, 79, 0.12);
  padding: 20rpx;
  box-sizing: border-box;
  position: relative;
}

.qr-ring {
  position: absolute;
  inset: 16rpx;
  border-radius: 22rpx;
  border: 2rpx dashed rgba(143, 199, 111, 0.6);
}

.qr-grid {
  position: relative;
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  gap: 8rpx;
}

.qr-block {
  border-radius: 10rpx;
  background: #173313;
}

.qr-block.wide {
  background: #8be85b;
}

.qr-block.tall {
  background: #44673a;
}

.qr-copy {
  flex: 1;
}

.qr-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.qr-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6f7e6c;
}

.seat-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.seat-summary-card {
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
}

.seat-summary-card.good {
  background: #edf9e9;
}

.seat-summary-card.warn {
  background: #fff7e7;
}

.seat-summary-card.mute {
  background: #eef2ef;
}

.seat-summary-label {
  display: block;
  font-size: 20rpx;
  color: #73806f;
}

.seat-summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.station-card,
.pay-card,
.summary-card {
  padding: 24rpx;
  margin-top: 18rpx;
}

.station-row,
.summary-line {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.station-block,
.summary-item {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f7fbf3;
}

.station-label,
.summary-label {
  display: block;
  font-size: 20rpx;
  color: #73806f;
}

.station-value,
.summary-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.station-scroll {
  margin-top: 16rpx;
  white-space: nowrap;
}

.station-chip-row,
.pay-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 2rpx 0 10rpx;
  flex-wrap: wrap;
}

.station-chip,
.pay-chip {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(96, 128, 87, 0.14);
  color: #597055;
  font-size: 22rpx;
  font-weight: 800;
}

.station-chip.is-active,
.pay-chip.is-active {
  background: linear-gradient(135deg, #b5ff63, #8ae85a);
  color: #173313;
  border-color: transparent;
}

.toggle-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 12rpx;
}

.toggle-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(100, 135, 92, 0.1);
}

.toggle-item:first-child {
  border-top: none;
}

.toggle-title {
  font-size: 26rpx;
  font-weight: 900;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6f7e6c;
}

.confirm-button {
  margin-top: 18rpx;
}
