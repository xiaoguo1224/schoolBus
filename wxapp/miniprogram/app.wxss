page {
  height: 100%;
  background: #f7f9f5;
  color: #1d261d;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  height: 100vh;
  background: #f7f9f5;
}

.page-body {
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(56, 88, 50, 0.08);
  border-radius: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
  margin: 24rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1d261d;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a7867;
  line-height: 1.5;
}

.muted {
  color: #6a7867;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ec;
  color: #4c6744;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button,
.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.primary-button {
  background: #2f7f47;
  color: #ffffff;
}

.ghost-button {
  background: #f3f6f2;
  color: #355037;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6f2;
  color: #4b6444;
  font-size: 20rpx;
  font-weight: 700;
}

.cell {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(56, 88, 50, 0.08);
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #edf4ea;
  color: #4c6744;
  font-size: 20rpx;
  font-weight: 700;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: #fafcf8;
  border: 1rpx solid rgba(56, 88, 50, 0.08);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #758071;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #1d261d;
}

.stat-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6a7867;
}

.list-card {
  padding: 22rpx;
}

.divider {
  height: 1rpx;
  margin: 18rpx 0;
  background: rgba(56, 88, 50, 0.08);
}

.safe-bottom {
  height: 64rpx;
}
